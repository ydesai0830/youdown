generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Trip {
  id          String        @id @default(cuid())
  title       String
  destination String?
  startDate   DateTime?
  endDate     DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  reservations Reservation[]
}

model Reservation {
  id                 String          @id @default(cuid())
  tripId             String
  type               String
  title              String
  provider           String?
  confirmationNumber String?
  startAt            DateTime?
  endAt              DateTime?
  location           String?
  notes              String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}
